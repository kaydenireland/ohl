public int main() {
    string s = null;
    print(s);
    char c = null;
    print(c);
    foo();
    return 0;
}

public null foo() {
    int x = 4;
    boolean even = isEven(x);
    print(even);
}


public boolean isEven(int x) {
    int rem = x % 2;
    if (rem == 0) return true;
    
    return false;
}
